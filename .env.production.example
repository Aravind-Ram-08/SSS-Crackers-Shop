# ============================================================
# PRODUCTION Environment Variables — SSS Crackers
# ============================================================
# Copy this file to .env (never commit the real .env)
# Set these values in Vercel Dashboard → Project → Settings → Environment Variables

# Razorpay PUBLIC key (safe to expose — starts with rzp_live_ for production)
VITE_RAZORPAY_KEY_ID=rzp_live_XXXXXXXXXXXXXXXX

# Backend API URL — Replace with your actual deployed backend URL
# Example: https://sss-crackers-api.onrender.com
VITE_API_URL=https://your-backend-url.onrender.com
